#!/usr/bin/env zsh
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${0}")/../" && pwd)"
LOG_DIR="$REPO_ROOT/docs/log"
META_FILE="${1:-${2:+docs}/today-commit/_meta.json}"

mkdir -p "$LOG_DIR"

AUTHOR=$(git config user.name || echo "unknown")
COMMIT_DATE_ISO="\"$(date '+%Y-%m-%d')\":\n    "
LAST_COMMIT_TS="$(cd "${REPO_ROOT}" && git log --pretty=format:'at %ad' 1>/dev/null)"

echo '=> today'"s activity logs...'

# Generate valid JSON with printf
printf '%b\n{\tmeta: {date:\"%(%Y-%m-%d)s\", author:%q, } \n}' -v date_iso $COMMIT_DATE_ISO || \
cat > "${META_FILE}" << EOFJSON

{
  meta:
    {
      "author":"$AUTHOR"
     }
}
EOF
print ''